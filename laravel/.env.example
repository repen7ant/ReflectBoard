APP_NAME=ReflectBoard
APP_ENV=local
APP_KEY=base64:uI8q2Bv704DJvx0zS4I37ZX4qABqrLXOZ9o+FOzjVFE=
APP_DEBUG=true
APP_URL=http://reflectboard.local
API_URL=http://reflectboard-api.local/api/v1
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ====================== DATABASE ======================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=reflectboard
DB_USERNAME=reflectboard
DB_PASSWORD=reflectboard

# ====================== REDIS ======================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ====================== CACHE & SESSION ======================
CACHE_STORE=redis
CACHE_PREFIX=reflectboard

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ====================== QUEUE & BROADCAST ======================
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

# ====================== FILESYSTEM ======================
FILESYSTEM_DISK=local

# ====================== MAIL ======================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525

# ====================== Additional ======================
VITE_APP_NAME="${APP_NAME}"

# ====================== Github OAuth ======================
GITHUB_CLIENT_ID=твой_client_id
GITHUB_CLIENT_SECRET=твой_client_secret
GITHUB_REDIRECT_URI=http://reflectboard.local/auth/github/callback

# ====================== Telegram Bot ======================
TELEGRAM_BOT_USERNAME=your_bot_username
