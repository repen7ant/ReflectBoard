[mysqld]
# ─── Memory ───────────────────────────────────────────
# ~50% of container limit (768M). Most important parameter for performance.
innodb_buffer_pool_size = 384M

# Redo log size. Larger → fewer checkpoints, better for write-heavy workloads.
innodb_log_file_size    = 64M

# Don't use OS page cache for data — avoids double-buffering.
innodb_flush_method     = O_DIRECT

# Flush log once per second instead of on every commit.
# Slightly faster writes, risk of losing up to 1s of transactions on crash — acceptable.
innodb_flush_log_at_trx_commit = 2

# ─── Connections ──────────────────────────────────────
# Default 151 — overkill for a personal project. Each connection costs ~1-2M.
max_connections         = 50

# ─── Charset (for Laravel) ────────────────────────────
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# ─── Profiling disabled ───────────────────────────────
# performance_schema saves ~100-200M RAM. Enable if diagnostics needed.
performance_schema      = OFF

# ─── Slow query log ───────────────────────────────────
slow_query_log          = ON
long_query_time         = 1
slow_query_log_file     = /var/lib/mysql/slow.log
